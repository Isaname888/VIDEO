 icon"><use href="/cdn/assets/sprites-core-0da2cb3c.svg#6d87e1" fill="currentColor"></use></svg></div></button></span><div aria-label="Переключить вид" class="group relative flex gap-0.5 rounded-full p-0.5 bg-token-bg-secondary dark:bg-gray-1000"><div aria-hidden="true" class="bg-token-bg-primary pointer-events-none absolute start-0.5 top-0.5 h-8 w-8 rounded-full" style="transform: none;"></div><span class="" data-state="closed"><button type="button" aria-label="Код" aria-pressed="true" class="relative flex h-8 w-8 items-center justify-center transition-colors text-token-text-primary group-hover:text-token-text-secondary hover:text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true"><use href="/cdn/assets/sprites-core-0da2cb3c.svg#00f12a" fill="currentColor"></use></svg></button></span><span class="" data-state="closed"><button type="button" aria-label="Предварительный просмотр" aria-pressed="false" aria-disabled="false" class="relative flex h-8 w-8 items-center justify-center transition-colors text-token-text-secondary group-hover:text-token-text-secondary hover:text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true"><use href="/cdn/assets/sprites-core-0da2cb3c.svg#6ef7a4" fill="currentColor"></use></svg></button></span></div></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="relative"><div class="w-full overflow-x-hidden overflow-y-auto" style="transform: none; max-height: 433px;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span>.bg-video {</span><br><span>  position: fixed;</span><br><span>  top: 0;</span><br><span>  left: 0;</span><br><span>  width: 100%;</span><br><span>  height: 100%;</span><br><span>  object-fit: cover;</span><br><span>  z-index: -1;</span><br><br><span>  filter: brightness(0.4) saturate(1.5);</span><br><span>}</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<hr data-start="1047" data-end="1050">
<h1 data-section-id="v6g7a" data-start="1052" data-end="1069">🌑 ЧТО ЭТО ДАЁТ</h1>
<p data-start="1071" data-end="1199">✔ видео как фон сайта<br data-start="1092" data-end="1095">
✔ затемнение (чтобы текст читался)<br data-start="1129" data-end="1132">
✔ неон-эффект<br data-start="1145" data-end="1148">
✔ выглядит как сайт стартапа / игры / Apple style</p>
<hr data-start="1201" data-end="1204">
<h1 data-section-id="nvnhob" data-start="1206" data-end="1231">🔥 КАК ДОЛЖНО ВЫГЛЯДЕТЬ</h1>
<ul data-start="1233" data-end="1367">
<li data-section-id="sjc68d" data-start="1233" data-end="1268">
<p data-start="1235" data-end="1268">фон = движущийся неоновый город</p>
</li>
<li data-section-id="l77b8z" data-start="1269" data-end="1294">
<p data-start="1271" data-end="1294">сверху = твой лендинг</p>
</li>
<li data-section-id="4aca1" data-start="1295" data-end="1335">
<p data-start="1297" data-end="1335">кнопки + текст = на затемнённом фоне</p>
</li>
<li data-section-id="19gv8le" data-start="1336" data-end="1367">
<p data-start="1338" data-end="1367">выглядит как <strong data-start="1351" data-end="1367">дорогой сайт</strong></p>
</li>
</ul>
<hr data-start="1369" data-end="1372">
<h1 data-section-id="mon53e" data-start="1374" data-end="1409">⚠️ ВАЖНО (ОТВЕТ НА ТВОЮ ПРОБЛЕМУ)</h1>
<p data-start="1411" data-end="1450">26 МБ — это нормально для видео ❗<br data-start="1444" data-end="1447">
НО:</p>
<ul data-start="1451" data-end="1511">
<li data-section-id="31919o" data-start="1451" data-end="1472">
<p data-start="1453" data-end="1472">лучше 5–15 секунд</p>
</li>
<li data-section-id="1z0yf4f" data-start="1473" data-end="1487">
<p data-start="1475" data-end="1487">лучше 720p</p>
</li>
<li data-section-id="1608068" data-start="1488" data-end="1511">
<p data-start="1490" data-end="1511">без звука (или muted)</p>
</li>
</ul>
<hr data-start="1513" data-end="1516">
<h1 data-section-id="na7vco" data-start="1518" data-end="1553">💬 ЕСЛИ ХОЧЕШЬ Я СДЕЛАЮ ЕЩЁ ЛУЧШЕ</h1>
<p data-start="1555" data-end="1567">Я могу тебе:</p>
<ul data-start="1568" data-end="1763">
<li data-section-id="10t8ug8" data-start="1568" data-end="1650">
<p data-start="1570" data-end="1650">💎 встроить это видео прямо в твой neon-лендинг (чтобы выглядело как сайт Tesla)</p>
</li>
<li data-section-id="18x45ei" data-start="1651" data-end="1704">
<p data-start="1653" data-end="1704">🚀 сделать автозатемнение + glow текст поверх видео</p>
</li>
<li data-section-id="ag6i1a" data-start="1705" data-end="1763">
<p data-start="1707" data-end="1763">📱 или адаптировать под телефон (очень важно для оценки)</p>
</li>
</ul>
<p data-start="1765" data-end="1773">Скажи 👍</p>
